graph TD
    subgraph "Central Layer"
        CCU["Central Computing Unit<br/>(Path Planning & Behavior Control)"]
    end

    subgraph "Communication Layer"
        SW["Central Switch<br/>(Packet Forwarding)"]
    end

    subgraph "Zonal Layer"
        FECU["Front Zonal ECU<br/>(Sense & Front Wheel Control)"]
        RECU["Rear Zonal ECU<br/>(Sense & Rear Wheel Control)"]
    end

    subgraph "Actuators & Sensors"
        FW["Front Wheel Motor"]
        RW["Rear Wheel Motor"]
        FS["Front Sensors"]
        RS["Rear Sensors"]
    end

    %% Connections
    CCU <--> SW
    SW <--> FECU
    SW <--> RECU
    
    FECU <--> FW
    FECU <--> FS
    
    RECU <--> RW
    RECU <--> RS
